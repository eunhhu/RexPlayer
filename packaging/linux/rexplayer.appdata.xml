<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.rexplayer.RexPlayer</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>RexPlayer</name>
  <summary>Lightweight high-performance Android app player</summary>

  <description>
    <p>
      RexPlayer is a lightweight, high-performance Android app player built on
      native hypervisor APIs (KVM on Linux, Hypervisor.framework on macOS,
      WHPX on Windows). It provides near-native execution speed with minimal
      resource overhead.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Hardware-accelerated virtualization via native hypervisor APIs</li>
      <li>GPU passthrough with Virgl and Venus renderer support</li>
      <li>Multi-instance management with copy-on-write cloning</li>
      <li>Virtio device stack (block, net, input, GPU, vsock)</li>
      <li>CPU optimization with vCPU pinning and topology-aware scheduling</li>
      <li>Snapshot save and restore</li>
      <li>Frida integration for dynamic instrumentation</li>
      <li>Qt-based GUI with touch input emulation</li>
    </ul>
  </description>

  <launchable type="desktop-id">rexplayer.desktop</launchable>

  <url type="homepage">https://github.com/rexplayer/rexplayer</url>
  <url type="bugtracker">https://github.com/rexplayer/rexplayer/issues</url>

  <provides>
    <binary>rexplayer</binary>
  </provides>

  <screenshots>
    <screenshot type="default">
      <caption>RexPlayer main window running an Android application</caption>
      <image>https://raw.githubusercontent.com/rexplayer/rexplayer/main/docs/screenshots/main-window.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.1.0" date="2026-03-16">
      <description>
        <p>Initial release with core virtualization features:</p>
        <ul>
          <li>KVM/HVF/WHPX hypervisor backends</li>
          <li>Virtio device stack</li>
          <li>Qt GUI with display and input handling</li>
          <li>Multi-instance management</li>
          <li>CPU optimization module</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>
</component>
